# Add local binaries to the PATH
export PATH=${HOME}/.local/bin:${HOME}/bin:${PATH}

# Colour in the CLI and when listing files/directories
export CLICOLOR=1
export LSCOLORS=gxfxbEaEBxxEhEhBaDaCaD

# History
export HISTFILE=${HOME}/.zsh_history
export HISTSIZE=50000
export SAVEHIST=50000
setopt SHARE_HISTORY        # share history across sessions
setopt HIST_IGNORE_ALL_DUPS # do not record duplicates
setopt HIST_REDUCE_BLANKS   # strip superfluous blanks
setopt HIST_VERIFY          # confirm history expansion before running

# Homebrew first so everything else can find brew-installed tools
source ${HOME}/.zsh/homebrew.zsh

# Completion (fpath must be set by homebrew.zsh before compinit)
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

# Modular configuration
source ${HOME}/.zsh/aliases.zsh
source ${HOME}/.zsh/functions.zsh
source ${HOME}/.zsh/direnv.zsh
source ${HOME}/.zsh/tmux.zsh
source ${HOME}/.zsh/git.zsh
source ${HOME}/.zsh/gh.zsh
source ${HOME}/.zsh/vim.zsh
source ${HOME}/.zsh/ssh.zsh
source ${HOME}/.zsh/gpg.zsh
source ${HOME}/.zsh/go.zsh
source ${HOME}/.zsh/python.zsh

# Load API keys and secrets from ~/.keys
source ${HOME}/.zsh/keys.zsh

# Load any local stuff (i.e., not checked-in to the dotfiles repo)
[[ -f ${HOME}/.zsh_local ]] && source ${HOME}/.zsh_local

# iTerm2 shell integration
if [[ "${LC_TERMINAL}" == "iTerm2" ]] && [[ -f ${HOME}/.iterm2_shell_integration.zsh ]]
then
  source ${HOME}/.iterm2_shell_integration.zsh
fi

# Prompt
type starship &>/dev/null && eval "$(starship init zsh)"

# Autosuggestions and syntax highlighting (highlighting must be last)
[[ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]] \
  && source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
[[ -f /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] \
  && source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
