#!/bin/bash

# Exit on error
set -e

echo "==> Configuring shell environment"

# Set zsh as the default shell if it isn't already
if [[ "$SHELL" != *"/zsh" ]]; then
  echo "Setting zsh as default shell..."
  chsh -s /bin/zsh
fi

# Install iTerm2 shell integration for zsh
if [ ! -f "$HOME/.iterm2_shell_integration.zsh" ]; then
  echo "Installing iTerm2 shell integration for zsh..."
  curl -fsSL https://iterm2.com/shell_integration/zsh \
    -o "$HOME/.iterm2_shell_integration.zsh"
fi

echo "✓ Shell configuration complete"
